# ─── Sanity CMS ──────────────────────────────────────────────────────────────
# Replace PLACEHOLDER_FILL_FROM_HANDOFF with the real 8-character alphanumeric
# projectId once Mack creates the Sanity project (see docs/SETUP-CHECKLIST.md
# §1). A placeholder fallback lives in sanity/env.ts so the build still passes
# pre-provisioning. Public dataset is required on Sanity's free tier.
NEXT_PUBLIC_SANITY_PROJECT_ID=PLACEHOLDER_FILL_FROM_HANDOFF
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# When 'true', the app reads live content from Sanity. When unset/'false',
# it renders the hardcoded fallbacks in app/_components/fallbacks/* (useful
# for offline dev or to avoid Sanity API calls). Production sets this to
# 'true' on Vercel — mirror it locally to match prod behavior.
NEXT_PUBLIC_USE_SANITY=true

# Optional read token — only needed for higher rate limits or private
# datasets. Public datasets work without it.
SANITY_API_READ_TOKEN=

# Server-only write token — used by the on-demand revalidation webhook in
# app/api/revalidate. NEVER prefix with NEXT_PUBLIC_.
SANITY_API_WRITE_TOKEN=

# Shared secret for /api/preview draft mode handshake.
SANITY_STUDIO_PREVIEW_SECRET=

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── SEO & Analytics ─────────────────────────────────────────────────────────
# Production should set NEXT_PUBLIC_SITE_URL=https://bruinalphainvestment.com
# (no trailing slash). All canonical URLs, sitemap entries, OG image URLs,
# and JSON-LD @id values derive from this.

# Google Search Console site verification meta-tag content (from the
# "HTML tag" verification method at https://search.google.com/search-console).
# Just the content string, e.g. "abc123...". Leave blank to skip emitting tag.
NEXT_PUBLIC_GSC_VERIFICATION=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). When set, the GA4
# gtag script is injected globally. Leave blank to skip.
NEXT_PUBLIC_GA_ID=
