{
  "name": "bai-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "analyze": "ANALYZE=true next build",
    "test:e2e": "playwright test",
    "test:lh": "lhci autorun",
    "seed": "bunx tsx sanity/seed/seed.ts",
    "migrate:camelcase": "bun run --bun sanity/seed/migrate-to-camelcase.ts",
    "backup": "bunx sanity dataset export production backup-$(date +%Y%m%d).tar.gz",
    "typegen:schema": "bunx sanity@latest schema extract --workspace default --path ./sanity.schema.json",
    "typegen": "bun run typegen:schema && bunx sanity typegen generate"
  },
  "dependencies": {
    "@portabletext/react": "^6.2.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/preview-url-secret": "^4.0.6",
    "@sanity/vision": "^5.25.0",
    "@sanity/visual-editing": "^5.3.4",
    "@sanity/webhook": "^4.0.4",
    "@studio-freight/react-lenis": "^0.0.47",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next": "16.2.6",
    "next-sanity": "^12.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanity": "^5.25.0",
    "styled-components": "^6.4.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@sanity/codegen": "^6.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-tailwindcss": "^3",
    "prettier": "^3",
    "prettier-plugin-tailwindcss": "^0.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "@lhci/cli": "^0.15.1"
  },
  "overrides": {
    "yargs-parser": "^21.1.1"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
